{% extends "govuk/template.njk" %}
{% from "govuk/components/header/macro.njk" import govukHeader %}
{% from "govuk/components/footer/macro.njk" import govukFooter %}
{% from "govuk/components/service-navigation/macro.njk" import govukServiceNavigation %}
{% from "govuk/components/phase-banner/macro.njk" import govukPhaseBanner %}

{% block head %}
  <link href="{{ '/assets/css/index.css' | assetMap }}" rel="stylesheet" />
{% endblock %}

{% block pageTitle %}
  {% set pageTitlePrefix = "" %}
  {% if validationErrors %}
    {% set pageTitlePrefix = t('common.pageTitle.errorPrefix') %}
  {% endif %}
  {% set applicationName = t('common.serviceName') %}
  {{ pageTitlePrefix + pageTitle + ' - ' + applicationName if pageTitle else pageTitlePrefix + applicationName }}
{% endblock %}

{% block header %}
  {{ govukHeader({
    homepageUrl: "/"
  }) }}
    <section aria-label="Service information" class="govuk-service-navigation" data-module="govuk-service-navigation" data-govuk-service-navigation-init="">
      <div class="govuk-width-container">
        <div class="govuk-service-navigation__container hmpps-language-toggle__container">
          <span class="govuk-service-navigation__service-name">
            <span class="govuk-service-navigation__text">{{ t('common.serviceName') }}</span>
          </span>
          {% include "partials/languageToggle.njk" %}
        </div>
      </div>
    </section>
    {{
      govukPhaseBanner({
      tag: {
        text: t('common.phaseBanner.tag')
      },
      html: t('common.phaseBanner.htmlNoLink') if hideFeedbackLink else t('common.phaseBanner.html')
      })
    }}
{% endblock %}

{% block bodyStart %}
{% endblock %}

{% block footer %}
  {{
    govukFooter({
    meta: {
    items: [
          {
            href: "/guidance",
            text: t('common.footer.guidance')
          },
          {
            href: "/cookies",
            text: t('common.footer.cookies')
          },
          {
            href: "/privacy-notice",
            text: t('common.footer.privacy')
          },
          {
            href: "/accessibility",
            text: t('common.footer.accessibility')
          }
        ]
    },
    contentLicence: { html: t('common.footer.openGovLicence') },
    copyright: { text: t('common.footer.crownCopyright') }
    })
  }}
{% endblock %}

{% block bodyEnd %}
  <script type="module" src="{{ '/assets/js/index.js' | assetMap }}"></script>
  {% if submissionAuthorized %}
    <script type="application/javascript">
      document.body.dataset.submissionId = '{{ submissionId }}'
    </script>
    <script type="module" src="{{ '/assets/js/timeout.js' | assetMap }}"></script>
  {% endif %}
{% endblock %}
