{% from "govuk/components/button/macro.njk" import govukButton %}
<div class="es-pane" id="fallbackReviewScreen" hidden aria-hidden="true">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ t('submission.liveness.fallback.partials.review.heading') }}</h1>
      <p>{{ t('submission.liveness.fallback.partials.review.rulesIntro') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ t('submission.liveness.fallback.partials.review.rules.litArea') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.review.rules.plainBackground') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.review.rules.faceInFrame') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.review.rules.noHatSunglasses') }}</li>
      </ul>
      <div class="videoRecorder__container">
        <div class="videoRecorder__videoWrap">
          <img id="fallbackReviewImage" class="videoRecorder__video" alt="{{ t('submission.liveness.fallback.partials.review.imageAlt') }}" />
        </div>
      </div>
      <p>
        {{ t('submission.liveness.fallback.partials.review.ifMeetsRules') }}
      </p>
      <div class="govuk-button-group">
        {{ govukButton({ text: t('submission.liveness.fallback.partials.review.continue'), element: "a", attributes: { "data-fallback-continue": "" } }) }}
        {{ govukButton({ text: t('submission.liveness.fallback.partials.review.recordAgain'), classes: "govuk-button--secondary", element: "a", attributes: { "data-fallback-video": "" } }) }}
      </div>
    </div>
  </div>
</div>
