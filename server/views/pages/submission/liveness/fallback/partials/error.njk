{% from "govuk/components/button/macro.njk" import govukButton %}
<div class="es-pane" id="fallbackErrorScreen" hidden aria-hidden="true">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ t('submission.liveness.fallback.partials.error.heading') }}</h1>
      <p>{{ t('submission.liveness.fallback.partials.error.intro') }}</p>
      <p class="govuk-!-font-weight-bold">{{ t('submission.liveness.fallback.partials.error.rulesIntro') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ t('submission.liveness.fallback.partials.error.rules.litArea') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.error.rules.plainBackground') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.error.rules.faceInFrame') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.error.rules.noHatSunglasses') }}</li>
      </ul>
      <div class="govuk-button-group">
        {{ govukButton({ text: t('submission.liveness.fallback.partials.error.tryAgain'), element: "a", attributes: { "data-fallback-video": "" } }) }}
      </div>
    </div>
  </div>
</div>
