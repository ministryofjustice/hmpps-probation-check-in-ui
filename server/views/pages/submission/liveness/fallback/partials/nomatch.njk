{% from "govuk/components/button/macro.njk" import govukButton %}
<div class="es-pane" id="fallbackNoMatchScreen" hidden aria-hidden="true">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ t('submission.liveness.fallback.partials.nomatch.heading') }}</h1>
      <p>{{ t('submission.liveness.fallback.partials.nomatch.intro') }}</p>
      <h2 class="govuk-heading-m">{{ t('submission.liveness.fallback.partials.nomatch.rulesHeading') }}</h2>
      <p>{{ t('submission.liveness.fallback.partials.nomatch.rulesIntro') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ t('submission.liveness.fallback.partials.nomatch.rules.litArea') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.nomatch.rules.plainBackground') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.nomatch.rules.faceInFrame') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.nomatch.rules.noHatSunglasses') }}</li>
      </ul>
      <div class="govuk-button-group">
        {{ govukButton({ text: t('submission.liveness.fallback.partials.nomatch.recordAgain'), element: "a", attributes: { "data-fallback-video": "" } }) }}
        {{ govukButton({ text: t('submission.liveness.fallback.partials.nomatch.submitAnyway'), classes: "govuk-button--secondary", href: "/" + submissionId + "/liveness/check-your-answers" }) }}
      </div>
    </div>
  </div>
</div>
