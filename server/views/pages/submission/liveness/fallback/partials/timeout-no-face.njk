{% from "govuk/components/button/macro.njk" import govukButton %}
{# Timeout where we never got a clear, centred look at the user — lead with positioning help. #}
<div class="es-pane" id="fallbackTimeoutNoFaceScreen" hidden aria-hidden="true">
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ t('submission.liveness.fallback.partials.timeoutNoFace.heading') }}</h1>
      <p>{{ t('submission.liveness.fallback.partials.timeoutNoFace.intro') }}</p>
      <p class="govuk-!-font-weight-bold">{{ t('submission.liveness.fallback.partials.timeoutNoFace.rulesIntro') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ t('submission.liveness.fallback.partials.timeoutNoFace.rules.litArea') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.timeoutNoFace.rules.faceInFrame') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.timeoutNoFace.rules.holdStill') }}</li>
        <li>{{ t('submission.liveness.fallback.partials.timeoutNoFace.rules.noHatSunglasses') }}</li>
      </ul>
      <p data-fallback-capped hidden aria-hidden="true">{{ t('submission.liveness.fallback.partials.capped') }}</p>
      <div class="govuk-button-group">
        {{ govukButton({ text: t('submission.liveness.fallback.partials.timeoutNoFace.tryAgain'), element: "a", attributes: { "data-fallback-retry": "" } }) }}
        {{ govukButton({ text: t('submission.liveness.fallback.partials.timeoutNoFace.submitAnyway'), classes: "govuk-button--secondary", href: "/" + submissionId + "/liveness/check-your-answers" }) }}
      </div>
    </div>
  </div>
</div>
