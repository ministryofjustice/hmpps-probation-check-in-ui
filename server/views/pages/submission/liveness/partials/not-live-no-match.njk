{% from "govuk/components/button/macro.njk" import govukButton %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l">{{ t('submission.liveness.partials.notLiveNoMatch.heading') }}</h1>
    <p>{{ t('submission.liveness.partials.notLiveNoMatch.intro') }}</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>{{ t('submission.liveness.partials.notLiveNoMatch.reasons.noMatch') }}</li>
      <li>{{ t('submission.liveness.partials.notLiveNoMatch.reasons.notLive') }}</li>
    </ul>
    <p class="govuk-!-font-weight-bold">{{ t('submission.liveness.partials.notLiveNoMatch.rulesHeading') }}</p>
    <p>{{ t('submission.liveness.partials.notLiveNoMatch.rulesIntro') }}</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>{{ t('submission.liveness.partials.notLiveNoMatch.rules.faceInFrame') }}</li>
      <li>{{ t('submission.liveness.partials.notLiveNoMatch.rules.followInstructions') }}</li>
      <li>{{ t('submission.liveness.partials.notLiveNoMatch.rules.steadyPace') }}</li>
    </ul>
    <p>
      {{ t('submission.liveness.partials.notLiveNoMatch.submitHint') }}
    </p>
    <div class="govuk-button-group">
      {{ govukButton({ text: t('submission.liveness.partials.notLiveNoMatch.verifyAgain'), href: "/" + submissionId + "/liveness/record" }) }}
      {{ govukButton({ text: t('submission.liveness.partials.notLiveNoMatch.continueToAnswers'), classes: "govuk-button--secondary", href: "/" + submissionId + "/liveness/check-your-answers" }) }}
    </div>
  </div>
</div>
