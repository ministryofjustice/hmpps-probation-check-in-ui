{% from "govuk/components/button/macro.njk" import govukButton %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l">{{ t('submission.liveness.partials.multipleFaces.heading') }}</h1>
    <p>
      {{ t('submission.liveness.partials.multipleFaces.intro') }}
    </p>
    <p class="govuk-!-font-weight-bold">{{ t('submission.liveness.partials.multipleFaces.rulesHeading') }}</p>
    <p>{{ t('submission.liveness.partials.multipleFaces.rulesIntro') }}</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>{{ t('submission.liveness.partials.multipleFaces.rules.faceInFrame') }}</li>
      <li>{{ t('submission.liveness.partials.multipleFaces.rules.followInstructions') }}</li>
      <li>{{ t('submission.liveness.partials.multipleFaces.rules.steadyPace') }}</li>
    </ul>
    <p>
      {{ t('submission.liveness.partials.multipleFaces.fallbackHint') }}
    </p>
    <div class="govuk-button-group">
      {{ govukButton({ text: t('submission.liveness.partials.multipleFaces.verifyAgain'), href: "/" + submissionId + "/liveness/record" }) }}
      {{ govukButton({ text: t('submission.liveness.partials.multipleFaces.recordInstead'), classes: "govuk-button--secondary", href: "/" + submissionId + "/liveness/fallback-inform" }) }}
    </div>
  </div>
</div>
