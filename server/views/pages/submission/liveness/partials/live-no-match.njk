{% from "govuk/components/button/macro.njk" import govukButton %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-two-thirds">
    <h1 class="govuk-heading-l">{{ t('submission.liveness.partials.liveNoMatch.heading') }}</h1>
    <p>{{ t('submission.liveness.partials.liveNoMatch.intro') }}</p>
    <p class="govuk-!-font-weight-bold">{{ t('submission.liveness.partials.liveNoMatch.rulesHeading') }}</p>
    <p>{{ t('submission.liveness.partials.liveNoMatch.rulesIntro') }}</p>
    <ul class="govuk-list govuk-list--bullet">
      <li>{{ t('submission.liveness.partials.liveNoMatch.rules.faceInFrame') }}</li>
      <li>{{ t('submission.liveness.partials.liveNoMatch.rules.litArea') }}</li>
      <li>{{ t('submission.liveness.partials.liveNoMatch.rules.plainBackground') }}</li>
      <li>{{ t('submission.liveness.partials.liveNoMatch.rules.noHatSunglasses') }}</li>
    </ul>
    <p>
      {{ t('submission.liveness.partials.liveNoMatch.submitHint') }}
    </p>
    <div class="govuk-button-group">
      {{ govukButton({ text: t('submission.liveness.partials.liveNoMatch.verifyAgain'), href: "/" + submissionId + "/liveness/record" }) }}
      {{ govukButton({ text: t('submission.liveness.partials.liveNoMatch.continueToAnswers'), classes: "govuk-button--secondary", href: "/" + submissionId + "/liveness/check-your-answers" }) }}
    </div>
  </div>
</div>
