{% from "govuk/components/button/macro.njk" import govukButton %}
{% extends "../../../partials/layout.njk" %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      <h1 class="govuk-heading-l">{{ t('submission.liveness.index.heading') }}</h1>
      <p>
        {{ t('submission.liveness.index.intro') }}
      </p>
      <h2 class="govuk-heading-m">{{ t('submission.liveness.index.beforeStart.heading') }}</h2>
      <p>{{ t('submission.liveness.index.beforeStart.intro') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ t('submission.liveness.index.beforeStart.items.internet') }}</li>
        <li>{{ t('submission.liveness.index.beforeStart.items.camera') }}</li>
        <li>{{ t('submission.liveness.index.beforeStart.items.details') }}</li>
      </ul>
      <p>{{ t('submission.liveness.index.beforeStart.uk') }}</p>
      <h2 class="govuk-heading-m">{{ t('submission.liveness.index.whatToDo.heading') }}</h2>
      <p>{{ t('submission.liveness.index.whatToDo.intro') }}</p>
      <ul class="govuk-list govuk-list--bullet">
        <li>{{ t('submission.liveness.index.whatToDo.items.questions') }}</li>
        <li>{{ t('submission.liveness.index.whatToDo.items.camera') }}</li>
        <li>
          {{ t('submission.liveness.index.whatToDo.items.verify') }}
        </li>
      </ul>
      <p>
        {{ t('submission.liveness.index.whatToDo.comparison') }}
      </p>
      <p>{{ t('submission.liveness.index.whatToDo.shareAnswers') }}</p>

      <h2 class="govuk-heading-m">{{ t('submission.liveness.index.help.heading') }}</h2>
      <p>
        {{ t('submission.liveness.index.help.intro') }}
      </p>
      <p class="govuk-body">{{ t('submission.liveness.index.help.guidance', { submissionId: submissionId }) | safe }}</p>
      <form action="/{{ submissionId }}/start" method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        {{
          govukButton({
          text: t('submission.liveness.index.start'),
          isStartButton: true
          })
        }}
      </form>
    </div>
  </div>
{% endblock %}
