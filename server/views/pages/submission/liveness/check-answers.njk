{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/back-link/macro.njk" import govukBackLink %}
{% from "govuk/components/checkboxes/macro.njk" import govukCheckboxes %}
{% from "govuk/components/summary-list/macro.njk" import govukSummaryList %}
{% from "../../../partials/errorSummary.njk" import errorSummary %}
{% extends "../../../partials/layout.njk" %}

{% set pageTitle = t('submission.checkAnswers.title') %}

{% block beforeContent %}
  {{
    govukBackLink({
      text: t('common.buttons.back'),
      href: "/" + submissionId + "/liveness/view"
    })
  }}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {{ errorSummary(validationErrors, t('common.errorSummary.title')) }}

      <h1 class="govuk-heading-l">{{ pageTitle }}</h1>

      <h2 class="govuk-heading-m">{{ t('submission.checkAnswers.aboutYou') }}</h2>

      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealth') }}</dt>
          <dd class="govuk-summary-list__value">{{ formData['mentalHealth'] | userFriendlyString }}</dd>
          <dd class="govuk-summary-list__actions">
            <a class="govuk-link" href="/{{ submissionId }}/questions/mental-health?checkAnswers=true"
              >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealth') }}</span></a
            >
          </dd>
        </div>

        {% if formData['mentalHealth'] == 'VERY_WELL' and formData['mentalHealthVeryWell'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealthVeryWell') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['mentalHealthVeryWell'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/mental-health?checkAnswers=true">
                {{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealthVeryWell') }}</span>
              </a>
            </dd>
          </div>
        {% endif %}

        {% if formData['mentalHealth'] == 'WELL' and formData['mentalHealthWell'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealthWell') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['mentalHealthWell'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/mental-health?checkAnswers=true">
                {{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealthWell') }}</span>
              </a>
            </dd>
          </div>
        {% endif %}

        {% if formData['mentalHealth'] == 'OK' and formData['mentalHealthOk'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealthOk') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['mentalHealthOk'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/mental-health?checkAnswers=true">
                {{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealthOk') }}</span>
              </a>
            </dd>
          </div>
        {% endif %}

        {% if formData['mentalHealth'] == 'NOT_GREAT' and formData['mentalHealthNotGreat'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealthNotGreat') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['mentalHealthNotGreat'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/mental-health?checkAnswers=true">
                {{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealthNotGreat') }}</span>
              </a>
            </dd>
          </div>
        {% endif %}

        {% if formData['mentalHealth'] == 'STRUGGLING' and formData['mentalHealthStruggling'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealthStruggling') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['mentalHealthStruggling'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/mental-health?checkAnswers=true">
                {{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealthStruggling') }}</span>
              </a>
            </dd>
          </div>
        {% endif %}
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.assistance') }}</dt>
          <dd class="govuk-summary-list__value">
            {% for a in formData['assistance'] | split(",") %}
              {{ a | userFriendlyString }}{% if not loop.last %},{% endif %}
            {% endfor %}
          </dd>
          <dd class="govuk-summary-list__actions">
            <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
              >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.assistance') }}</span></a
            >
          </dd>
        </div>

        {% if formData['mentalHealthSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.mentalHealthSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['mentalHealthSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.mentalHealthSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}

        {% if formData['alcoholSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.alcoholSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['alcoholSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.alcoholSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}
        {% if formData['drugsSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.drugsSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['drugsSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.drugsSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}
        {% if formData['moneySupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.moneySupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['moneySupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.moneySupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}
        {% if formData['housingSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.housingSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['housingSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.housingSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}

        {% if formData['employmentEduSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.employmentEduSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['employmentEduSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.employmentEduSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}

        {% if formData['supportSystemSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.supportSystemSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['supportSystemSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.supportSystemSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}

        {% if formData['otherSupport'] %}
          <div class="govuk-summary-list__row">
            <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.otherSupport') }}</dt>
            <dd class="govuk-summary-list__value">{{ formData['otherSupport'] }}</dd>
            <dd class="govuk-summary-list__actions">
              <a class="govuk-link" href="/{{ submissionId }}/questions/assistance?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.otherSupport') }}</span></a
              >
            </dd>
          </div>
        {% endif %}

        {% if formData['additionalAnswers'] and formData['additionalAnswers'].length %}
          {% for item in formData['additionalAnswers'] %}
            <div class="govuk-summary-list__row">
              <dt class="govuk-summary-list__key">{{ item.question }}</dt>
              <dd class="govuk-summary-list__value">{{ item.response }}</dd>
              <dd class="govuk-summary-list__actions">
                <a class="govuk-link" href="/{{ submissionId }}/questions/additional/{{ loop.index }}?checkAnswers=true"
                  >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.additionalPrefix') }}{{ item.question | lower }}</span></a
                >
              </dd>
            </div>
          {% endfor %}
        {% endif %}
      </dl>

      <h2 class="govuk-heading-m">{{ t('submission.checkAnswers.identityCheck') }}</h2>

      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">{{ t('submission.checkAnswers.rows.identityCheck') }}</dt>

          <dd class="govuk-summary-list__value">
            {% if isLive == true and autoVerifyResult == 'MATCH' %}
              {{ t('submission.checkAnswers.identityResult.match') }}
            {% elif isLive == true and autoVerifyResult == 'NO_MATCH' %}
              {{ t('submission.checkAnswers.identityResult.noMatch') }}
            {% elif isLive == false and autoVerifyResult == 'MATCH' %}
              {{ t('submission.checkAnswers.identityResult.notLiveMatch') }}
            {% elif isLive == false and autoVerifyResult == 'NO_MATCH' %}
              {{ t('submission.checkAnswers.identityResult.notLiveNoMatch') }}
            {% elif autoVerifyResult == 'MATCH' %}
              {{ t('submission.checkAnswers.identityResult.match') }}
            {% elif autoVerifyResult == 'NO_MATCH' %}
              {{ t('submission.checkAnswers.identityResult.noMatch') }}
            {% else %}
              {{ t('submission.checkAnswers.identityResult.noMatch') }}
            {% endif %}
          </dd>
          <dd class="govuk-summary-list__actions">
            {% if (isLive == true and autoVerifyResult == 'MATCH') or (isLive == undefined and autoVerifyResult == 'MATCH') %}
              <a class="govuk-link" href="/{{ submissionId }}/liveness/view?checkAnswers=true"
                >{{ t('submission.checkAnswers.view') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.identity') }}</span></a
              >
            {% elif isLive == true or isLive == false %}
              <a class="govuk-link" href="/{{ submissionId }}/liveness/record?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.identity') }}</span></a
              >
            {% else %}
              <a class="govuk-link" href="/{{ submissionId }}/liveness/fallback-record?checkAnswers=true"
                >{{ t('submission.checkAnswers.change') }}<span class="govuk-visually-hidden">{{ t('submission.checkAnswers.hidden.identity') }}</span></a
              >
            {% endif %}
          </dd>
        </div>
      </dl>

      <form method="POST">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}" />
        <input type="hidden" id="device-data" name="deviceData" />

        {{
          govukCheckboxes({
            name: "checkAnswers",
            errorMessage: validationErrors | findError("checkAnswers"),
            fieldset: {
              legend: {
                classes: "govuk-fieldset__legend--m",
                text: t('submission.checkAnswers.complete.legend')
              }
            },
            items: [
              {
                value: "CONFIRM",
                text: t('submission.checkAnswers.complete.confirm')
              }
            ]
          })
        }}

        {{
          govukButton({
            text: t('submission.checkAnswers.complete.button')
          })
        }}
      </form>
    </div>
  </div>
{% endblock %}

{% block bodyEnd %}
  {{ super() }} <script type="module" src="{{ '/assets/js/detect-device.js' | assetMap }}"></script>
{% endblock %}
